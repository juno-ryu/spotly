generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// AI 리포트 — 리포트 생성 시에만 저장
model AnalysisReport {
  id            String   @id @default(cuid())

  address       String   // 검색 주소
  industryName  String   // 업종명
  totalScore    Float    // 종합 점수 (0-100)
  scoreDetail   Json?    // 세부 점수

  aiReportJson  Json     // AI 리포트 구조화 데이터

  /// Supabase Auth 사용자 ID (비로그인 시 null)
  userId        String?

  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([createdAt(sort: Desc)])
}

/// 전국 초중고 학교 위치 정보 (정적 데이터, CSV seed)
model School {
  id            String   @id @default(cuid())
  /// 공공데이터 학교 고유 ID
  schoolId      String   @unique
  /// 학교명
  name          String
  /// 학교급 (초등학교 / 중학교 / 고등학교)
  level         String
  /// 위도
  lat           Float
  /// 경도
  lng           Float
  /// 소재지 도로명주소
  address       String
  /// 설립형태 (공립 / 사립 / 국립)
  establishType String

  @@index([lat])
  @@index([lng])
}
